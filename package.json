{
  "name": "gmail-smart-cleaner",
  "version": "1.0.0",
  "description": "A production-ready Google Apps Script to automatically organize, label, and clean your Gmail inbox.",
  "private": true,
  "scripts": {
    "login": "clasp login",
    "logout": "clasp logout",
    "create": "clasp create --type standalone --title \"Gmail Smart Cleaner\" --rootDir ./src",
    "pull": "clasp pull",
    "push": "clasp push --force",
    "deploy": "clasp push --force",
    "open": "clasp open",
    "webapp": "clasp open --webapp",
    "format": "prettier --write \"**/*.{js,gs,json,md,html}\"",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "release": "semantic-release",
    "fix": "npm run lint:fix"
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^1.0.83",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-googleappsscript": "^1.0.4",
    "prettier": "^3.3.2",
    "semantic-release": "^24.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
